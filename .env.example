# ============================================================
# Sierra Estates — Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local to version control.
#
# This file is the canonical list of every variable the app reads.
# Keep it in sync: a CI sweep of process.env.* vs this file
# is the source of truth.
# ============================================================

# ─── Firebase Client SDK (public; NEXT_PUBLIC_* ships to browser) ───
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Admin SDK (server-side only; NEVER expose) ───
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative: full service-account JSON as one string
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Internal Auth / Security ───
# Shared secret checked by lib/server/auth-guard.ts (X-SBR-SECRET-KEY header)
SBR_SECRET_KEY=
# Used by backend webhook verification (validate-env.ts REQUIRED)
X_SE_SECRET_KEY=
# API key for property sync endpoint
SYNC_API_KEY=
CRON_SECRET=

# ─── AI / Gemini ───
# Required by validate-env.ts — server will NOT start without this
GOOGLE_AI_API_KEY=

# ─── WhatsApp — sender pool (E.164 digits, no leading +) ───
# Used by both the Meta Cloud API integration and lib/server/whatsapp-queue.ts
# (Twilio outbound queue: round-robin load balancing, 30 msg/2hr per number).
# Current 4 dedicated numbers: +201032206443, +201092048333, +201061399688, +201031622700.
WABA_NUMBER_1=
WABA_NUMBER_2=
WABA_NUMBER_3=
WABA_NUMBER_4=
WHATSAPP_API_TOKEN=
WHATSAPP_META_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
BRANDING_TAG=

# ─── WhatsApp — Twilio (outbound sending via lib/server/twilio-client.ts +
# lib/server/whatsapp-queue.ts) ───
# Each WABA_NUMBER_1-4 above must be a Twilio WhatsApp-approved sender on this account.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ─── Telegram (alerts + webhook) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Email (SendGrid — primary) ───
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Alternative email provider
RESEND_API_KEY=

# ─── Email (Gmail SMTP — fallback) ───
GMAIL_USER=
GMAIL_PASS=

# ─── Upstash Redis (rate-limiting + WhatsApp outbound queue) ───
# When set, public endpoints (lib/server/rate-limit.ts) and the WhatsApp
# outbound queue (lib/server/whatsapp-queue.ts) share this Redis instance.
# When unset, both fall back to a per-instance in-memory counter/queue —
# fine for local dev, NOT safe for a multi-instance Vercel deploy.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Google Sheets (ingestion + sync) ───
GOOGLE_SERVICE_ACCOUNT_KEY=
BROKER_INBOX_SHEET_ID=
MASTER_SHEET_ID=

# ─── Property Finder API ───
PROPERTY_FINDER_API_BASE=https://api.propertyfinder.com.eg/v3
PROPERTY_FINDER_JWT_TOKEN=
PROPERTY_FINDER_WEBHOOK_SECRET=
PROPERTY_FINDER_API_GATEWAY=
PROPERTY_FINDER_API_KEY=
PROPERTY_FINDER_API_SECRET=
PROPERTY_FINDER_CLIENT_ID=
PROPERTY_FINDER_CLIENT_SECRET=

# ─── Maps & reCAPTCHA (client) ───
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── App Config / URLs ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=
DATABASE_URL=file:./db/custom.db
PORT=3000
BASE_PATH=

# ─── Expo / Mobile App ───
EXPO_PUBLIC_BACKEND_URL=
EXPO_PUBLIC_OPENCLAW_KEY=
EXPO_PUBLIC_WA_PHONE_ID=
EXPO_PUBLIC_WA_TOKEN=
EXPO_PUBLIC_WA_VERIFY_TOKEN=sierra_hermes_2026
EXPO_PUBLIC_AGENT_PHONE=

# ─── WhatsApp Bot / Agents ───
SE_API_URL=
HEARTBEAT_INTERVAL=
AGENT_PHONE=

# ─── OpenClaw AI Gateway ───
OPENCLAW_BASE_URL=
OPENCLAW_TOKEN=

# ─── Integration Endpoints ───
ZAPIER_CALENDAR_WEBHOOK_URL=

# ─── Voice (Leila TTS) ───
ELEVENLABS_API_KEY=
LEILA_VOICE_ID=

# ─── Error Monitoring (Sentry) ───
# Get from https://sentry.io/settings/projects/ → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ─── Observability (Arize) ───
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=

# ─── Memory Engine (packages/memory-engine) ───
MEMORY_PERSISTENCE=
MEMORY_LEARNING=
MEMORY_AUDIT=