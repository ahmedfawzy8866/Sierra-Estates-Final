# ══════════════════════════════════════════════════════════════════════════════
# SIERRA ESTATES — VERCEL ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
# 1. Fill in all the values marked with "your-..." below.
# 2. Go to Vercel -> Your Project -> Settings -> Environment Variables.
# 3. Copy ALL the text in this file and paste it into the FIRST "Key" input box. 
#    Vercel will automatically parse all the variables for you.
# 4. Do this for BOTH projects (some variables are for Realty, some for Admin).

# --- Firebase Project Configuration (Next.js / Realty App) ---
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sierra-estates
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sierra-estates.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://sierra-estates.firebaseio.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sierra-estates.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# --- Firebase Project Configuration (Vite / Admin Portal) ---
VITE_FIREBASE_PROJECT_ID=sierra-estates
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=sierra-estates.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=sierra-estates.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# --- Firebase Admin SDK (Choose ONE method) ---
# Method 1: Provide the entire Service Account JSON (Recommended)
FIREBASE_SERVICE_ACCOUNT_JSON=your-service-account-json-content

# Method 2: Provide specific keys if Method 1 is not used
# FIREBASE_CLIENT_EMAIL=your-client-email
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Key-Here\n-----END PRIVATE KEY-----\n"

# --- Third-Party Integrations ---
PROPERTY_FINDER_API_KEY=your-property-finder-api-key
SBR_SECRET_KEY=your-sbr-secret-key
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your-telegram-bot-username
SENDGRID_API_KEY=your-sendgrid-api-key
SENDER_EMAIL=noreply@sierraestatesrealty.com

# --- Application Settings ---
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_APP_URL=https://your-production-url.vercel.app
ALLOWED_ORIGINS=https://admin.sierra-estates.net,https://sierra-estates.net,http://localhost:3000

NEXT_PUBLIC_PYTHON_API_URL=http://localhost:8000
