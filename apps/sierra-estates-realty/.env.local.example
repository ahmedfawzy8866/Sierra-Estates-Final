# ============================================================
# Sierra Estates — Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local to version control.
# ============================================================

# ==========================================
# FIREBASE CLIENT CONFIG (Public - Safe for browser)
# These NEXT_PUBLIC_* vars ship to the browser.
# ==========================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ==========================================
# FIREBASE ADMIN CONFIG (SECRET - Server-only)
# NEVER expose these to the browser.
# Strategy 1: Use FIREBASE_SERVICE_ACCOUNT_JSON (recommended)
# Strategy 2: Use individual vars below
# ==========================================
FIREBASE_SERVICE_ACCOUNT_JSON=
# OR use individual vars:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Note: In Vercel, paste the private key exactly as it appears
# in the JSON (including \n for newlines).
FIREBASE_PRIVATE_KEY=

# ==========================================
# INTERNAL AUTH / SERVICE SECRETS
# ==========================================
# Shared secret for service-to-service and webhook auth
# Generate with: openssl rand -hex 32
SBR_SECRET_KEY=
CRON_SECRET=
JWT_SECRET=
ENCRYPTION_KEY=

# ==========================================
# AI PROVIDERS
# ==========================================
GOOGLE_AI_API_KEY=
GOOGLE_GENAI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=
AI_PROVIDER=
GOOGLE_CLOUD_LOCATION=europe-west1

# ==========================================
# WHATSAPP — Meta Cloud API
# ==========================================
WABA_NUMBER_1=
WABA_NUMBER_2=
WABA_NUMBER_3=
WABA_NUMBER_4=
WHATSAPP_API_TOKEN=
WHATSAPP_META_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
BRANDING_TAG=

# ==========================================
# WHATSAPP — Twilio (outbound sending)
# ==========================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# ==========================================
# TELEGRAM (alerts + webhook)
# ==========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ==========================================
# UPSTASH REDIS (distributed rate-limiting)
# When BOTH are set, public endpoints use shared Redis.
# When unset, falls back to per-instance in-memory counter.
# ==========================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==========================================
# n8n WORKFLOW ENGINE
# ==========================================
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ==========================================
# AIRTABLE (lead/listing ingestion)
# ==========================================
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# ==========================================
# GOOGLE SHEETS (ingestion + sync)
# ==========================================
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
MASTER_SHEET_ID=
BROKER_INBOX_SHEET_ID=

# ==========================================
# VOICE (Leila TTS)
# ==========================================
ELEVENLABS_API_KEY=
LEILA_VOICE_ID=

# ==========================================
# OBSERVABILITY (Arize)
# ==========================================
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=

# ==========================================
# WORKFLOW / INTEGRATION ENDPOINTS
# ==========================================
PYTHON_API_BASE_URL=http://localhost:8000
OPENCLAW_BASE_URL=
OPENCLAW_TOKEN=
ZAPIER_CALENDAR_WEBHOOK_URL=

# ==========================================
# EMAIL (Gmail SMTP)
# ==========================================
GMAIL_USER=
GMAIL_PASS=

# ==========================================
# MAPS & RECAPTCHA (client)
# ==========================================
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ==========================================
# APP CONFIG
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_INTELLIGENCE_OS_URL=
# admin.sierra-estates.net — enables admin host-split in middleware
ADMIN_HOST=
# Comma-separated origins allowed by CORS
ALLOWED_ORIGINS=

# ==========================================
# PROPERTY FINDER
# ==========================================
PROPERTY_FINDER_API_KEY=
