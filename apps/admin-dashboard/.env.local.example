# ══════════════════════════════════════════════════════════════════════════════
# FIREBASE CONFIGURATION (client SDK)
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in values from the Sierra Estates
# Firebase project (Console -> Project Settings -> General -> Your apps).
# Same project as apps/sierra-estates-realty — these values are not secret.

NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# ══════════════════════════════════════════════════════════════════════════════
# FIREBASE ADMIN SDK (server-side only — keep secret, never commit real values)
# ══════════════════════════════════════════════════════════════════════════════
# Preferred: a single service-account JSON (raw or base64-encoded).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Fallback: individual service-account fields.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# API AUTH
# ══════════════════════════════════════════════════════════════════════════════
# Shared secret accepted by verifyRequest() for service/cron calls
# (sent as the X-SE-SECRET-KEY header). Keep in sync with any caller config.
SE_SECRET_KEY=
