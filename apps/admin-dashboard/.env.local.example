# ══════════════════════════════════════════════════════════════════════════════
# FIREBASE CONFIGURATION (client SDK)
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in values from the Sierra Blu
# Firebase project (Console -> Project Settings -> General -> Your apps).
# Canonical project: sierra-blu (matches .firebaserc).

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBZLN2jTTKV34SneGPoWRz1zoRpX5uODjs
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sierra-blu.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sierra-blu
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sierra-blu.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=941030513456
NEXT_PUBLIC_FIREBASE_APP_ID=1:941030513456:web:56209a1495d69f217086f5
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-ZP054BPJ8Q

# ══════════════════════════════════════════════════════════════════════════════
# FIREBASE ADMIN SDK (server-side only — keep secret, never commit real values)
# ══════════════════════════════════════════════════════════════════════════════
# Preferred: a single service-account JSON (raw or base64-encoded).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Fallback: individual service-account fields.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# API AUTH
# ══════════════════════════════════════════════════════════════════════════════
# Shared secret accepted by verifyRequest() for service/cron calls
# (sent as the X-SE-SECRET-KEY header). Keep in sync with any caller config.
SE_SECRET_KEY=
