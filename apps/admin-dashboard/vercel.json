{
  "version": 2,
  "buildCommand": "cd ../.. && pnpm --filter admin-dashboard build",
  "outputDirectory": "dist",
  "installCommand": "corepack enable && cd ../.. && pnpm install",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}

