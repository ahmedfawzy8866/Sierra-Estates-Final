{
  "version": 2,
  "buildCommand": "npm run build:server",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/server.cjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.cjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
