{
  "version": 2,
  "buildCommand": "cd ../.. && pnpm --filter admin-dashboard build",
  "outputDirectory": "dist",
  "installCommand": "npm install --prefix ../../ --legacy-peer-deps",
  "functions": {
    "api/server.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
