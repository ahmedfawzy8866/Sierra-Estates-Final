{
  "name": "sierra-estates-platform",
  "version": "1.0.0",
  "description": "Sierra Estates 1.0 - Master Monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:realty": "pnpm --filter sierra-blu-realty dev",
    "dev:admin": "pnpm --filter sierra-blu-admin-portal dev",
    "build:realty": "pnpm --filter sierra-blu-realty build",
    "build:admin": "pnpm --filter sierra-blu-admin-portal build",
    "bootstrap:memory": "node scripts/bootstrap-vector-memory.js",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
