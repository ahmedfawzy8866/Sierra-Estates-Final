# ============================================================
# Sierra Estates — Comprehensive Gitignore
# ============================================================

# ─── Compiled output ───
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/
.next/
out/
build/
.turbo/

# ─── Dependencies ───
node_modules/
.pnp
.pnp.js

# ─── IDEs and editors ───
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ─── Environment variables and secrets ───
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
*.pem
docs/secrets.local.md

# ─── Firebase service accounts (NEVER commit) ───
*serviceAccount*.json
firebase-adminsdk-*.json

# ─── Misc ───
/.sass-cache
/connect.lock
/coverage/
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings
__pycache__/
*.pyc
*.egg-info/
.venv/

# ─── WhatsApp scraper session data ───
.wwebjs_auth/
.wwebjs_cache/

# ─── System Files ───
.DS_Store
Thumbs.db

# ─── Cursor / AI rules ───
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ─── Replit ───
.cache/
.local/

# ─── Agent skills ───
.agents/
skills-lock.json

# ─── Firebase cache & logs ───
.firebase/
firebase-debug.log
firestore-debug.log

# ─── Vercel ───
.vercel

# ─── Logs ───
*.log

# ─── Archive (local only) ───
_archive/
back/

# ─── Large binary assets (use Firebase Storage instead) ───
*.zip
*.tar.gz
*.bin
